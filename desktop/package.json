{
  "name": "@legioncodeinc/apiary-desktop",
  "version": "0.11.1",
  "private": true,
  "description": "Apiary Desktop Shell - Electron main process that supervises the fleet and renders the Hive dashboard in a native window.",
  "type": "module",
  "main": "dist/main/main.js",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "npm run build && electron .",
    "check-fleet-versions": "node scripts/check-fleet-versions.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "dist": "npm run build && npm run check-fleet-versions && electron-builder",
    "dist:dir": "npm run build && npm run check-fleet-versions && electron-builder --dir"
  },
  "fleetVersions": {
    "honeycomb": "0.22.0",
    "doctor": "0.6.0",
    "hive": "0.12.0",
    "nectar": "0.3.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "zod": "^4.4.3"
  }
}
