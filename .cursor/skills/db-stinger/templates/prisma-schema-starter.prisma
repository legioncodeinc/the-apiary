// Prisma Schema Starter — db-stinger template
//
// Opinionated starter for a Postgres schema using Prisma.
// Replace `User`, `Post`, `Order` with your own models.
//
// Defaults baked in:
// - BigInt for IDs (`@default(autoincrement())` — generated as IDENTITY in PG 16+).
// - DateTime with @db.Timestamptz for all timestamps.
// - String (Postgres `text` by default) — never @db.VarChar(255) without a reason.
// - Decimal for money — never Float.
// - Explicit `@@index([fk_column])` for every FK (Prisma does not auto-create FK indexes).
// - `@@map` and `@map` to keep snake_case in the database while camelCase in app.
//
// Source: guides/01-schema-design.md, guides/07-orm-choice.md.

generator client {
  provider = "prisma-client-js"
  // For serverless: enable runtime "edge" or "nodejs" target as appropriate.
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For pooled connections via PgBouncer transaction mode:
  // url      = env("DATABASE_URL_POOLED")
  // directUrl = env("DATABASE_URL_DIRECT")  // for migrations
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  refunded

  @@map("order_status")
}

model User {
  id        BigInt    @id @default(autoincrement())
  email     String    @unique
  createdAt DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime  @updatedAt @db.Timestamptz @map("updated_at")
  deletedAt DateTime? @db.Timestamptz @map("deleted_at")
  metadata  Json?     @db.JsonB

  posts  Post[]
  orders Order[]

  @@index([email])
  @@map("users")
}

model Post {
  id        BigInt   @id @default(autoincrement())
  authorId  BigInt   @map("author_id")
  title     String
  body      String
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId]) // MUST-FIX rule: every FK gets an index
  @@map("posts")
}

model Order {
  id         BigInt      @id @default(autoincrement())
  userId     BigInt      @map("user_id")
  status     OrderStatus @default(pending)
  totalCents Decimal     @db.Decimal(12, 0) @map("total_cents")
  createdAt  DateTime    @default(now()) @db.Timestamptz @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("orders")
}

// Notes:
//
// 1. CHECK constraints, partial indexes, EXCLUDE constraints, and many advanced
//    Postgres features are not expressible in Prisma's schema language. Add them
//    via raw SQL migrations:
//
//    -- prisma/migrations/<n>_add_constraints.sql
//    ALTER TABLE posts ADD CONSTRAINT posts_title_not_empty CHECK (length(title) > 0);
//    CREATE INDEX orders_pending_created_idx ON orders (created_at) WHERE status = 'pending';
//    COMMENT ON COLUMN users.email IS 'PII';
//
// 2. For PgBouncer transaction mode, set ?pgbouncer=true on the pooled URL and
//    leave directUrl pointing at the unpooled endpoint for migrations.
//
// 3. For pgvector and other extensions, declare them in the migration:
//
//    CREATE EXTENSION IF NOT EXISTS vector;
//    ALTER TABLE documents ADD COLUMN embedding vector(1536);
//    CREATE INDEX ON documents USING hnsw (embedding vector_cosine_ops);
//
// 4. Prisma does not natively manage triggers. Add updated_at triggers via raw SQL.
