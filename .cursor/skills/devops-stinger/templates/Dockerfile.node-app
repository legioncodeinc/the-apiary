# Generic Node API Dockerfile
# Multi-stage, BuildKit cache mounts, non-root, HEALTHCHECK.
# Source: guides/01-dockerfile-patterns.md.
# Build: docker buildx build --target runtime -t app:latest .
# Or via Bake: depot bake app

# syntax=docker/dockerfile:1.7
ARG NODE_VERSION=20.18.1

# --- deps: production-only deps for the runtime image ---
FROM node:${NODE_VERSION}-alpine3.20 AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml* package-lock.json* yarn.lock* ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store,sharing=locked \
    --mount=type=cache,id=npm,target=/root/.npm,sharing=locked \
    if [ -f pnpm-lock.yaml ]; then \
        corepack enable && pnpm fetch --prod && pnpm install --prod --frozen-lockfile --offline; \
    elif [ -f yarn.lock ]; then \
        yarn install --production --frozen-lockfile; \
    else \
        npm ci --omit=dev; \
    fi

# --- builder: full deps + build ---
FROM node:${NODE_VERSION}-alpine3.20 AS builder
WORKDIR /app
COPY package.json pnpm-lock.yaml* package-lock.json* yarn.lock* ./
RUN --mount=type=cache,id=pnpm,target=/pnpm/store,sharing=locked \
    --mount=type=cache,id=npm,target=/root/.npm,sharing=locked \
    if [ -f pnpm-lock.yaml ]; then \
        corepack enable && pnpm install --frozen-lockfile; \
    elif [ -f yarn.lock ]; then \
        yarn install --frozen-lockfile; \
    else \
        npm ci; \
    fi
COPY . .
RUN --mount=type=cache,id=tsc,target=/app/.tsbuildinfo \
    npm run build

# --- runtime: minimal final image, non-root ---
FROM node:${NODE_VERSION}-alpine3.20 AS runtime
WORKDIR /app
ENV NODE_ENV=production \
    NODE_OPTIONS="--enable-source-maps" \
    PORT=3000

# Copy minimal artifacts only
COPY --from=deps   /app/node_modules ./node_modules
COPY --from=builder /app/dist        ./dist
COPY --from=builder /app/package.json ./

# Non-root user (the official node image includes "node" UID 1000)
USER node

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://localhost:'+(process.env.PORT||3000)+'/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))" || exit 1

# Use exec form so signals (SIGTERM) reach Node directly
CMD ["node", "dist/server.js"]

# --- example secret-mounted install (uncomment if you need a private registry) ---
# RUN --mount=type=secret,id=npmrc,target=/root/.npmrc \
#     --mount=type=cache,id=npm,target=/root/.npm \
#     npm ci --omit=dev
