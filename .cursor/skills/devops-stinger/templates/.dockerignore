# Canonical .dockerignore for Node / Next.js / TypeScript apps.
# Source: guides/01-dockerfile-patterns.md §7.

# Version control
.git
.gitignore
.gitattributes
.github

# Node / package managers
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store

# Build artifacts
dist
build
out
.next
.nuxt
.svelte-kit
.turbo
.cache
coverage
*.tsbuildinfo

# Environment & secrets — IMPORTANT
.env
.env.*
!.env.example
.secrets
.secrets/

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Test artifacts
playwright-report
test-results
.nyc_output

# Docs that don't ship
README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE
docs/
*.md
!**/migrations/*.md

# CI / local tooling
.husky
.lintstagedrc*
.prettier*
.eslintrc*
docker-compose*.yml
Dockerfile*
.dockerignore
docker-bake.hcl
Makefile
taskfile.yml

# Lockfiles for OTHER package managers (keep only the one you use)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
