// templates/agent-context-config.prisma
//
// Canonical AgentContextConfig shape. The thread-scope policy table for
// each agent type, per-tenant or platform-wide.
//
// Source-of-truth: library/knowledge-base/ai/agent-orchestration.md §3
// Code: lib/context-packet.ts (getThreadScope, getDefaultScope)

model AgentContextConfig {
  id                    String   @id @default(cuid())
  agentType             String   @map("agent_type")           // "main_community", "level_1", "module_goals", etc.
  tenantId              String?  @map("tenant_id")            // null = platform default
  threadScope           String   @default("cross_session") @map("thread_scope")
  isEnabled             Boolean  @default(true) @map("is_enabled")
  updatedBySuperAdminId String?  @map("updated_by_super_admin_id")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([agentType, tenantId])
  @@map("agent_context_configs")
}

// =============================================================================
// Scope values (validate at app layer; enum not used to allow future extension)
// =============================================================================
//
//   "thread_scoped"   — current conversation thread only
//   "cross_thread"    — multiple sessions of same agent type
//   "cross_session"   — all sessions, all agent types
//
// Default scope by agent type (in getDefaultScope()):
//
//   "onboarding" || "offer_doc"   → "thread_scoped"
//   starts with "module_"          → "cross_thread"
//   everything else                → "cross_session"
//
// If isEnabled === false, scope defaults to "cross_session" (disabled = unrestricted).
//
// =============================================================================
//
// IMPORTANT: scope is NOT a security boundary.
// Security is enforced by tenant_id and user_id filters on every Qdrant query,
// always present regardless of scope.
//
// =============================================================================

