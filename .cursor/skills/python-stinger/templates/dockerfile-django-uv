# Multi-stage Dockerfile for Django + uv.
#
# Build:    docker build -t myapp .
# Run dev:  docker run --rm -p 8000:8000 -e DJANGO_SETTINGS_MODULE=config.settings.dev myapp
# Run prod: docker run --rm -p 8000:8000 -e DJANGO_SETTINGS_MODULE=config.settings.prod myapp
#
# Cross-reference: the `devops-worker-bee` Stinger owns the deploy / orchestration
# / CI side. This Dockerfile is the Python-side runtime.

# ----------------------------- builder stage --------------------------------
FROM python:3.12-slim AS builder

# uv binary — copied from the official Astral image (no Python install needed)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# System deps for psycopg, Pillow, etc.
RUN apt-get update && apt-get install --no-install-recommends -y \
        build-essential \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies WITHOUT the project itself first — maximum cache reuse.
# Bind mounts ensure source files are visible without baking into a layer.
ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    uv sync --frozen --no-install-project --no-dev --no-editable

# Copy the project source and install it.
COPY . /app
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable

# Collect static files at build time (avoids requiring DB at boot).
RUN DJANGO_SETTINGS_MODULE=config.settings.prod \
    DJANGO_SECRET_KEY=build-only \
    DATABASE_URL=sqlite:///dev/null \
    REDIS_URL=redis://localhost:6379/0 \
    CELERY_BROKER_URL=redis://localhost:6379/0 \
    FRONTEND_ORIGIN=https://example.com \
    DJANGO_ALLOWED_HOSTS=example.com \
    EMAIL_HOST=localhost EMAIL_HOST_USER=u EMAIL_HOST_PASSWORD=p DEFAULT_FROM_EMAIL=a@b.c \
    /app/.venv/bin/python manage.py collectstatic --noinput

# ----------------------------- runtime stage --------------------------------
FROM python:3.12-slim AS runtime

RUN apt-get update && apt-get install --no-install-recommends -y \
        libpq5 \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid 1000 app \
    && useradd --uid 1000 --gid app --shell /bin/bash --create-home app

WORKDIR /app

# Copy the venv and source from the builder.
COPY --from=builder --chown=app:app /app /app

ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DJANGO_SETTINGS_MODULE=config.settings.prod

USER app

EXPOSE 8000

# Healthcheck (assumes /health endpoint — see guides/18-deployment-runtimes.md).
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl --fail --silent http://localhost:8000/health || exit 1

# Default to gunicorn (sync Django). Override CMD for ASGI / Daphne / Uvicorn.
CMD ["gunicorn", "config.wsgi:application", \
     "--bind", "0.0.0.0:8000", \
     "--workers", "4", \
     "--worker-class", "sync", \
     "--max-requests", "1000", \
     "--max-requests-jitter", "100", \
     "--timeout", "30", \
     "--access-logfile", "-", \
     "--error-logfile", "-"]
