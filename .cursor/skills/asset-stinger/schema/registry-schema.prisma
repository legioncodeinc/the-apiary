// ─────────────────────────────────────────────────────────────────────────────
// Universal Asset Registry — canonical Prisma fragment
// Owner: asset-worker-bee
// PRD: <asset-registry foundation feature PRD in the deploying product>
//
// This file is a REFERENCE. The real migration lands in the deploying product's
// schema.prisma via the product's migration flow (e.g., `pnpm prisma migrate dev`).
// Mirror shapes, map names, and index patterns.
//
// Conventions:
//   - every catalog model has `key String @unique` (stable code-side identifier)
//   - every catalog model has `status RegistryStatus @default(draft)`
//   - generator-owned fields are grouped at the bottom with a // ── Generator-owned ── marker
//   - every FK column uses @map("snake_case")
//   - @@map("snake_case_table_name")
// ─────────────────────────────────────────────────────────────────────────────

// ─── Shared enums ────────────────────────────────────────────────────────────

enum RegistryStatus {
  draft
  active
  deprecated
  archived
  orphaned
}

enum RegistryEnvironment {
  dev
  staging
  prod
}

enum RouteType {
  page
  api
  webhook_inbound
  webhook_outbound
  server_action
  middleware
  redirect
  cron
  rpc
}

enum RouteMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  WS
  NA
}

enum RouteAuth {
  public
  authed
  admin
  platform_admin
  service
}

enum SurfaceKind {
  card
  modal
  sheet
  nav
  popover
  toast
  panel
  drawer
}

enum SurfaceDepthLevel {
  flat
  raised
  floating
  glass
}

enum ControlKind {
  button
  input
  toggle
  select
  slider
  checkbox
  radio
  link
  menu_item
}

enum DisplayKind {
  badge
  avatar
  icon_label
  tag
  skeleton
  divider
  progress
  empty_state
}

enum DesignTokenCategory {
  color
  radius
  shadow
  blur
  space
  typography
  motion
  z_index
  opacity
  breakpoint
}

enum MotionKind {
  duration
  easing
  composite
}

enum MediaKind {
  image
  logo
  illustration
  lottie
  video
}

enum FontSource {
  google
  self_hosted
  system
}

enum ContentKind {
  string
  template
  rich
  markdown
  html
}

enum PiiLevel {
  none
  low
  high
}

enum TranslationStatus {
  draft
  machine_translated
  human_reviewed
  approved
}

enum FeaturePhase {
  proposed
  in_dev
  shipped
  deprecated
}

// ─── Catalog: Feature ────────────────────────────────────────────────────────

model Feature {
  id               String   @id @default(cuid())
  key              String   @unique
  displayName      String   @map("display_name")
  description      String   @default("")
  phase            FeaturePhase @default(proposed)
  meterable        Boolean  @default(false)
  defaultFlagSlug  String?  @map("default_flag_slug")
  ownerTeam        String   @map("owner_team")
  prdRef           String?  @map("prd_ref")
  planTiers        String[] @map("plan_tiers") @default([])
  status           RegistryStatus @default(draft)
  environments     RegistryEnvironment[] @default([dev, staging, prod])
  deprecatedAt     DateTime? @map("deprecated_at")
  sunsetAt         DateTime? @map("sunset_at")
  replacementKey   String?  @map("replacement_key")
  deprecationReason String? @map("deprecation_reason")
  notes            String?
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // ── Generator-owned ──
  codePath          String  @map("code_path")
  featureFilesHash  String  @map("feature_files_hash")
  detectedAt        DateTime @map("detected_at")
  lastSeenAt        DateTime @map("last_seen_at")

  pages             Page[]
  routes            Route[]
  surfaces          Surface[]
  controls          Control[]
  displays          Display[]
  layouts           Layout[]
  navEntries        NavEntry[]
  contentEntries    ContentEntry[]
  mediaAssets       MediaAsset[]
  entitlements      FeatureEntitlement[]

  @@index([phase])
  @@index([ownerTeam])
  @@index([status])
  @@map("features")
}

// ─── Catalog: Page ───────────────────────────────────────────────────────────

model Page {
  id                String   @id @default(cuid())
  key               String   @unique
  routeId           String?  @map("route_id")
  layoutId          String?  @map("layout_id")
  featureKey        String?  @map("feature_key")
  authRequirement   RouteAuth @default(authed) @map("auth_requirement")
  flagGate          String?  @map("flag_gate")
  planGate          String[] @map("plan_gate") @default([])
  fileType          String   @map("file_type")
  surfacesUsed      String[] @map("surfaces_used") @default([])
  controlsUsed      String[] @map("controls_used") @default([])
  displaysUsed      String[] @map("displays_used") @default([])
  contentKeysUsed   String[] @map("content_keys_used") @default([])
  status            RegistryStatus @default(draft)
  environments      RegistryEnvironment[] @default([dev, staging, prod])
  ownerTeam         String   @map("owner_team")
  prdRef            String?  @map("prd_ref")
  deprecatedAt      DateTime? @map("deprecated_at")
  sunsetAt          DateTime? @map("sunset_at")
  notes             String?
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // ── Generator-owned ──
  codePath          String   @map("code_path")
  fileHash          String   @map("file_hash")
  detectedAt        DateTime @map("detected_at")
  lastSeenAt        DateTime @map("last_seen_at")

  route             Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  layout            Layout?  @relation(fields: [layoutId], references: [id], onDelete: SetNull)
  feature           Feature? @relation(fields: [featureKey], references: [key], onDelete: SetNull, onUpdate: Cascade)

  @@index([featureKey])
  @@index([routeId])
  @@index([layoutId])
  @@index([status])
  @@map("pages")
}

// ─── Catalog: Route ──────────────────────────────────────────────────────────

model Route {
  id                 String   @id @default(cuid())
  key                String   @unique
  type               RouteType
  path               String
  method             RouteMethod
  featureKey         String?  @map("feature_key")
  renderedPageKey    String?  @map("rendered_page_key")
  auth               RouteAuth @default(authed)
  rateLimit          String?  @map("rate_limit")
  permissionsRequired String[] @map("permissions_required") @default([])
  version            String?
  externalContract   Boolean  @default(false) @map("external_contract")
  status             RegistryStatus @default(draft)
  environments       RegistryEnvironment[] @default([dev, staging, prod])
  ownerTeam          String   @map("owner_team")
  prdRef             String?  @map("prd_ref")
  deprecatedAt       DateTime? @map("deprecated_at")
  sunsetAt           DateTime? @map("sunset_at")
  notes              String?
  createdBy          String   @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // ── Generator-owned ──
  handlerFilePath    String   @map("handler_file_path")
  handlerExport      String   @map("handler_export")
  fileHash           String   @map("file_hash")
  openapiRef         String?  @map("openapi_ref")
  detectedAt         DateTime @map("detected_at")
  lastSeenAt         DateTime @map("last_seen_at")

  feature            Feature? @relation(fields: [featureKey], references: [key], onDelete: SetNull, onUpdate: Cascade)
  pages              Page[]
  navEntries         NavEntry[]

  @@unique([path, method, version])
  @@index([featureKey])
  @@index([type])
  @@index([auth])
  @@index([status])
  @@map("routes")
}

