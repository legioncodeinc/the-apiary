}

// ─── Catalog: FeatureEntitlement ─────────────────────────────────────────────

model FeatureEntitlement {
  id                String   @id @default(cuid())
  featureKey        String   @map("feature_key")
  planKey           String?  @map("plan_key")
  addonKey          String?  @map("addon_key")
  limitValue        Int?     @map("limit_value")
  limitMeterKey     String?  @map("limit_meter_key")
  softLimit         Boolean  @default(false) @map("soft_limit")
  hardLimit         Boolean  @default(false) @map("hard_limit")
  gracePeriodDays   Int?     @map("grace_period_days")
  status            RegistryStatus @default(draft)
  environments      RegistryEnvironment[] @default([dev, staging, prod])
  ownerTeam         String   @map("owner_team")
  prdRef            String?  @map("prd_ref")
  deprecatedAt      DateTime? @map("deprecated_at")
  sunsetAt          DateTime? @map("sunset_at")
  notes             String?
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  feature           Feature  @relation(fields: [featureKey], references: [key], onDelete: Restrict, onUpdate: Cascade)

  @@unique([featureKey, planKey, addonKey])
  @@index([planKey])
  @@index([addonKey])
  @@index([limitMeterKey])
  @@map("feature_entitlements")
}

// ─── Audit: registry_audit_log ───────────────────────────────────────────────

model RegistryAuditLog {
  id            String   @id @default(cuid())
  runId         String?  @map("run_id")
  actor         String
  tableName     String   @map("table_name")
  rowKey        String   @map("row_key")
  action        String
  before        Json?
  after         Json?
  justification String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tableName, rowKey])
  @@index([actor])
  @@index([createdAt])
  @@map("registry_audit_log")
}

