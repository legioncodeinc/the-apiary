  status          RegistryStatus @default(draft)
  environments    RegistryEnvironment[] @default([dev, staging, prod])
  ownerTeam       String   @map("owner_team")
  prdRef          String?  @map("prd_ref")
  deprecatedAt    DateTime? @map("deprecated_at")
  sunsetAt        DateTime? @map("sunset_at")
  notes           String?
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // ── Generator-owned ──
  codePath          String   @map("code_path")
  exportName        String   @map("export_name")
