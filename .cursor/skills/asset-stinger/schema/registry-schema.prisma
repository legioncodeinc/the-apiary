// ─── Catalog: NavEntry ───────────────────────────────────────────────────────

model NavEntry {
  id               String   @id @default(cuid())
  key              String   @unique
  section          String
  labelContentKey  String   @map("label_content_key")
  iconKey          String   @map("icon_key")
  routeKey         String?  @map("route_key")
  externalHref     String?  @map("external_href")
  parentKey        String?  @map("parent_key")
  sortOrder        Int      @default(0) @map("sort_order")
  visibilityRule   Json     @map("visibility_rule")
  permissionKey    String?  @map("permission_key")
  featureKey       String?  @map("feature_key")
  customizable     Boolean  @default(true)
  placement        String[] @default([])
  status           RegistryStatus @default(draft)
  environments     RegistryEnvironment[] @default([dev, staging, prod])
  ownerTeam        String   @map("owner_team")
  prdRef           String?  @map("prd_ref")
  deprecatedAt     DateTime? @map("deprecated_at")
  sunsetAt         DateTime? @map("sunset_at")
  notes            String?
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // ── Generator-owned ──
  codePath    String   @map("code_path")
  fileHash    String   @map("file_hash")
  detectedAt  DateTime @map("detected_at")
  lastSeenAt  DateTime @map("last_seen_at")

  parent      NavEntry?     @relation("NavEntryTree", fields: [parentKey], references: [key], onDelete: SetNull, onUpdate: Cascade)
  children    NavEntry[]    @relation("NavEntryTree")
  route       Route?        @relation(fields: [routeKey], references: [key], onDelete: SetNull, onUpdate: Cascade)
  feature     Feature?      @relation(fields: [featureKey], references: [key], onDelete: SetNull, onUpdate: Cascade)
  label       ContentEntry? @relation("NavEntryLabel", fields: [labelContentKey], references: [key], onDelete: Restrict, onUpdate: Cascade)

  @@index([section, sortOrder])
  @@index([featureKey])
  @@index([status])
  @@map("nav_entries")
}

