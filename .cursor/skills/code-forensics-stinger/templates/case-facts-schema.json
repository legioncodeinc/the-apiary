{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "case-facts.json",
  "description": "Accumulator for forensic-investigation facts across all 9 phases. Each phase writes its outputs here; the docx builders read from here to substitute placeholders.",
  "type": "object",
  "properties": {
    "project_name": { "type": "string", "description": "e.g., 'Example Booking Co.', 'Pioneer AMS'" },
    "project_slug": { "type": "string", "description": "filename-safe version, e.g., 'ExampleBooking'" },
    "client_legal_name": { "type": "string" },
    "client_principal": { "type": "string", "description": "Owner/managing member" },
    "client_address": { "type": "string" },
    "client_email": { "type": "string" },
    "client_phone": { "type": "string" },
    "engagement_start_date": { "type": "string", "format": "date" },
    "engagement_end_date": { "type": "string", "format": "date" },
    "engagement_months": { "type": "integer" },
    "termination_date": { "type": "string", "format": "date" },
    "original_contract_value": { "type": "number" },
    "original_contract_date": { "type": "string", "format": "date" },

    "jurisdiction": {
      "type": "object",
      "properties": {
        "primary_state": { "type": "string", "description": "default 'Ohio'" },
        "primary_county": { "type": "string", "description": "for venue, e.g., 'Cuyahoga County'" },
        "applicable_statutes": {
          "type": "array",
          "items": { "type": "object", "properties": { "name": {"type":"string"}, "citation": {"type":"string"} } }
        }
      }
    },

    "defendants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "profile_file": { "type": "string", "description": "path to defendant-profile-*.md" },
          "legal_name": { "type": "string" },
          "dba_names": { "type": "array", "items": { "type": "string" } },
          "principal": { "type": "string" },
          "role_in_engagement": { "type": "string", "description": "e.g., 'agency middleman', 'offshore developer'" }
        }
      }
    },

    "materials_available": {
      "type": "object",
      "properties": {
        "email_archive": { "type": "boolean" },
        "invoices_pdf": { "type": "boolean" },
        "invoices_eml": { "type": "boolean" },
        "git_repo": { "type": "boolean" },
        "wp_audit_log": { "type": "boolean" },
        "audit_reports": { "type": "boolean" },
        "account_reports": { "type": "boolean" },
        "signed_contracts": { "type": "boolean" }
      }
    },

    "phases_complete": {
      "type": "object",
      "properties": {
        "phase_0_intake": { "type": "boolean" },
        "phase_1_emails": { "type": "boolean" },
        "phase_2_invoices": { "type": "boolean" },
        "phase_3_git": { "type": "boolean" },
        "phase_4_cve": { "type": "boolean" },
        "phase_5_audit_log": { "type": "boolean" },
        "phase_6_marketing": { "type": "boolean" },
        "phase_7_deliverables": { "type": "boolean" },
        "phase_8_pre_litigation": { "type": "boolean" }
      }
    },

    "email_stats": {
      "type": "object",
      "properties": {
        "total_messages": { "type": "integer" },
        "thread_count": { "type": "integer" },
        "date_range": { "type": "array", "items": { "type": "string", "format": "date" }, "minItems": 2, "maxItems": 2 },
        "top_senders": { "type": "array", "items": { "type": "object", "properties": { "email": {"type":"string"}, "count": {"type":"integer"} } } },
        "stripe_account_ids_observed": { "type": "array", "items": { "type": "string" } }
      }
    },

    "totals": {
      "type": "object",
      "properties": {
        "documented_invoice_total": { "type": "number" },
        "extrapolated_invoice_total": { "type": "number" },
        "documented_plus_extrapolated_total": { "type": "number" },
        "client_reported_spend_low": { "type": "number" },
        "client_reported_spend_high": { "type": "number" },
        "unk_invoice_count": { "type": "integer" },
        "per_defendant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "documented": { "type": "number" },
              "extrapolated": { "type": "number" }
            }
          }
        }
      }
    },

    "git": {
      "type": "object",
      "properties": {
        "repo_name": { "type": "string" },
        "first_commit_date": { "type": "string", "format": "date" },
        "last_commit_date": { "type": "string", "format": "date" },
        "total_commits": { "type": "integer" },
        "total_hours_delivered": { "type": "number" },
        "value_at_100_per_hour": { "type": "number" },
        "value_at_30_per_hour_offshore": { "type": "number" },
        "active_months": { "type": "integer" },
        "idle_months": { "type": "array", "items": { "type": "string", "description": "YYYY-MM" } },
        "low_activity_months": { "type": "array", "items": { "type": "string" } },
        "primary_authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "commits": { "type": "integer" },
              "hours": { "type": "number" }
            }
          }
        },
        "claimed_hours_per_month": { "type": "number", "description": "e.g., 80 for $4,000/mo at $50/hr equivalent" },
        "claimed_hours_total": { "type": "number" },
        "unexplained_hour_gap": { "type": "number" },
        "maintenance_overpayment_at_100": { "type": "number" }
      }
    },

    "cve": {
      "type": "object",
      "properties": {
        "cms_versions_observed": { "type": "array", "items": { "type": "object" } },
        "theme_versions_observed": { "type": "array", "items": { "type": "object" } },
        "critical_cves_unpatched": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "component": { "type": "string" },
              "cvss": { "type": "number" },
              "disclosed_date": { "type": "string", "format": "date" },
              "actively_exploited": { "type": "boolean" },
              "patched_in_version": { "type": "string" },
              "client_patch_date": { "type": "string", "format": "date" },
              "days_unpatched": { "type": "integer" },
              "authoritative_source_url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },

    "wp_audit_log": {
      "type": "object",
      "properties": {
        "export_window": { "type": "array", "items": { "type": "string", "format": "date" } },
        "longest_gap_between_vendor_updates_days": { "type": "integer" },
        "automated_updates_during_gap": { "type": "array", "items": { "type": "object" } },
        "client_emergency_update_date": { "type": "string", "format": "date" },
        "plugins_updated_by_client_on_termination": { "type": "array", "items": { "type": "string" } }
      }
    },

    "marketing": {
      "type": "object",
      "properties": {
        "social_media_billed_per_month": { "type": "number" },
        "social_media_fair_value_low": { "type": "number" },
        "social_media_fair_value_high": { "type": "number" },
        "social_media_months_billed": { "type": "integer" },
        "social_media_overpayment_low": { "type": "number" },
        "social_media_overpayment_high": { "type": "number" },
        "engagement_rates_observed": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "gmb_reviews_during_engagement": { "type": "integer" },
        "gmb_website_visits_per_quarter": { "type": "integer" }
      }
    },

    "damages": {
      "type": "object",
      "properties": {
        "build_overpayment_low": { "type": "number" },
        "build_overpayment_high": { "type": "number" },
        "maintenance_overpayment_low": { "type": "number" },
        "maintenance_overpayment_high": { "type": "number" },
        "hosting_overcharge": { "type": "number" },
        "virtual_assistant_low": { "type": "number" },
        "virtual_assistant_high": { "type": "number" },
        "social_media_overcharge_low": { "type": "number" },
        "social_media_overcharge_high": { "type": "number" },
        "other_overcharges": { "type": "number" },
        "aggregate_low": { "type": "number" },
        "aggregate_high": { "type": "number" },
        "demand_per_defendant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "minimum": { "type": "number" },
              "maximum": { "type": "number" }
            }
          }
        }
      }
    },

    "plain_language_analogy": {
      "type": "string",
      "enum": ["house", "car", "kitchen", "tax", "wedding", "custom"],
      "default": "house",
      "description": "Which extended analogy to use in the Plain Language Report"
    },

    "deliverables_scope": {
      "type": "string",
      "enum": ["minimal", "standard", "full"],
      "default": "full",
      "description": "minimal = attorney memo + pre-lit pack only; standard = + master report; full = all 11 deliverables"
    },

    "report_version": { "type": "string", "description": "e.g., 'V1', 'V2', 'V3'" },
    "report_date": { "type": "string", "format": "date" }
  },

  "required": [
    "project_name",
    "client_legal_name",
    "engagement_start_date",
    "defendants"
  ]
}
